# Copy this file to `.env` and fill in real values.
# DATABASE_URL uses PostgreSQL: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jd2story?schema=public"

# LLM provider. Default config targets Qwen (DashScope OpenAI-compatible).
# - Qwen   : baseURL=https://dashscope.aliyuncs.com/compatible-mode/v1   model=qwen-plus / qwen-max
# - DeepSeek: baseURL=https://api.deepseek.com/v1                         model=deepseek-chat
# - Moonshot: baseURL=https://api.moonshot.cn/v1                          model=moonshot-v1-8k
# For Claude / OpenAI / Gemini, install the matching @ai-sdk/* adapter
# and edit src/lib/llm.ts.
LLM_API_KEY=""
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus"

# NextAuth — GitHub OAuth
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
