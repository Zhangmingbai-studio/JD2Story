# Production environment variables for Vercel.
# Do not commit real secrets.

# Neon production PostgreSQL for Vercel runtime.
# Copy the pooled connection string from Neon. It should include sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# For one-off Prisma migrations, temporarily set DATABASE_URL in your shell
# to Neon's direct/unpooled connection string instead of this pooled URL.

# LLM provider.
LLM_API_KEY=""
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus"

# NextAuth production config.
# NEXTAUTH_URL must match the final Vercel domain exactly.
NEXTAUTH_URL="https://your-project.vercel.app"
NEXTAUTH_SECRET=""

# GitHub OAuth App for production.
# Callback URL: https://your-project.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
